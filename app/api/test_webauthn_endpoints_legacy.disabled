"""
Tests for WebAuthn Authentication Endpoints (P0.3)

Tests for the new WebAuthn registration and authentication endpoints
that replace deprecated password authentication.
"""

import pytest
import json
from datetime import datetime
from unittest.mock import Mock, patch, AsyncMock
from fastapi.testclient import TestClient
from app.main import app


client = TestClient(app)


class TestWebAuthnRegisterStart:
    """Test WebAuthn registration start endpoint."""
    
    def test_register_start_returns_challenge(self):
        """Test: POST /webauthn/register/start returns challenge."""
        response = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": "newuser@example.com"}
        )
        
        assert response.status_code == 200
        data = response.json()
        
        # Should include challenge for attestation
        assert "challenge" in data
        assert len(data["challenge"]) > 0
        assert isinstance(data["challenge"], str)
    
    def test_register_start_returns_rp_entity(self):
        """Test: Challenge response includes RP entity information."""
        response = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": "newuser@example.com"}
        )
        
        assert response.status_code == 200
        data = response.json()
        
        # Should include RP entity (Relying Party)
        assert "rp" in data
        assert "name" in data["rp"]
        assert "id" in data["rp"]
    
    def test_register_start_returns_user_entity(self):
        """Test: Challenge response includes user entity."""
        response = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": "testuser@example.com"}
        )
        
        assert response.status_code == 200
        data = response.json()
        
        # Should include user entity
        assert "user" in data
        assert "id" in data["user"]
        assert "name" in data["user"]
        assert "displayName" in data["user"]
        assert data["user"]["name"] == "testuser@example.com"
    
    def test_register_start_returns_pubkey_creation_options(self):
        """Test: Challenge includes publicKeyCredentialCreationOptions."""
        response = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": "user123@example.com"}
        )
        
        assert response.status_code == 200
        data = response.json()
        
        # Should include authenticator selection and supported algorithms
        assert "authenticatorSelection" in data
        assert "pubKeyCredParams" in data


class TestWebAuthnRegisterFinish:
    """Test WebAuthn registration finish endpoint."""
    
    def test_register_finish_accepts_attestation(self):
        """Test: POST /webauthn/register/finish accepts attestation response."""
        response = client.post(
            "/api/v1/auth/webauthn/register/finish",
            json={
                "username": "newuser@example.com",
                "attestationResponse": {
                    "id": "credential-id",
                    "rawId": "credential-id-raw",
                    "type": "public-key",
                    "response": {
                        "clientDataJSON": "mock-client-data",
                        "attestationObject": "mock-attestation"
                    }
                }
            }
        )
        
        # Should accept the registration
        assert response.status_code in [200, 201]
    
    def test_register_finish_returns_confirmation(self):
        """Test: register/finish returns confirmation message."""
        response = client.post(
            "/api/v1/auth/webauthn/register/finish",
            json={
                "username": "user@example.com",
                "attestationResponse": {
                    "id": "cred-123",
                    "rawId": "cred-123-raw",
                    "type": "public-key",
                    "response": {
                        "clientDataJSON": "data",
                        "attestationObject": "object"
                    }
                }
            }
        )
        
        assert response.status_code in [200, 201]
        data = response.json()
        
        # Should indicate successful registration
        assert "message" in data or "status" in data


class TestWebAuthnAuthenticateStart:
    """Test WebAuthn authentication start endpoint."""
    
    def test_authenticate_start_returns_challenge(self):
        """Test: POST /webauthn/authenticate/start returns challenge."""
        response = client.post(
            "/api/v1/auth/webauthn/authenticate/start",
            json={"username": "user@example.com"}
        )
        
        assert response.status_code == 200
        data = response.json()
        
        # Should include challenge for assertion
        assert "challenge" in data
        assert len(data["challenge"]) > 0
    
    def test_authenticate_start_includes_allowed_credentials(self):
        """Test: Authentication challenge includes allowedCredentials."""
        response = client.post(
            "/api/v1/auth/webauthn/authenticate/start",
            json={"username": "user@example.com"}
        )
        
        assert response.status_code == 200
        data = response.json()
        
        # Should include allowCredentials for user's registered keys
        assert "allowCredentials" in data
        # Could be empty list if user has no credentials yet
        assert isinstance(data["allowCredentials"], list)
    
    def test_authenticate_start_timeout_specified(self):
        """Test: Authentication challenge includes timeout."""
        response = client.post(
            "/api/v1/auth/webauthn/authenticate/start",
            json={"username": "user@example.com"}
        )
        
        assert response.status_code == 200
        data = response.json()
        
        # Should include timeout
        assert "timeout" in data
        assert data["timeout"] > 0


class TestWebAuthnAuthenticateFinish:
    """Test WebAuthn authentication finish endpoint."""
    
    def test_authenticate_finish_accepts_assertion(self):
        """Test: POST /webauthn/authenticate/finish accepts assertion response."""
        response = client.post(
            "/api/v1/auth/webauthn/authenticate/finish",
            json={
                "username": "user@example.com",
                "assertionResponse": {
                    "id": "credential-id",
                    "rawId": "credential-id-raw",
                    "type": "public-key",
                    "response": {
                        "clientDataJSON": "mock-client-data",
                        "authenticatorData": "mock-auth-data",
                        "signature": "mock-signature"
                    }
                }
            }
        )
        
        # Should accept the authentication
        assert response.status_code in [200, 401, 403]
    
    def test_authenticate_finish_returns_grant_token(self):
        """Test: Successful authentication returns grant token."""
        response = client.post(
            "/api/v1/auth/webauthn/authenticate/finish",
            json={
                "username": "user@example.com",
                "assertionResponse": {
                    "id": "credential-id",
                    "rawId": "credential-id-raw",
                    "type": "public-key",
                    "response": {
                        "clientDataJSON": "data",
                        "authenticatorData": "auth",
                        "signature": "sig"
                    }
                }
            }
        )
        
        # For now, placeholder returns 200/201
        if response.status_code == 200:
            data = response.json()
            # Should include grant token or auth token
            assert "token" in data or "grant" in data or "message" in data


class TestPasswordAuthDeprecation:
    """Test that password authentication endpoints are deprecated."""
    
    def test_password_register_deprecated(self, caplog):
        """Test: POST /register logs deprecation warning."""
        response = client.post(
            "/api/auth/register",
            json={
                "username": "user@example.com",
                "password": "SecurePassword123!"
            }
        )
        
        # Should still work but log deprecation
        assert response.status_code in [200, 400]  # Could be 200 or 400 depending on impl
    
    def test_password_login_deprecated(self, caplog):
        """Test: POST /login logs deprecation warning."""
        response = client.post(
            "/api/auth/login",
            json={
                "username": "user@example.com",
                "password": "SecurePassword123!"
            }
        )
        
        # Should still work but log deprecation
        assert response.status_code in [200, 401, 400]


class TestWebAuthnEndpointValidation:
    """Test input validation for WebAuthn endpoints."""
    
    def test_register_start_requires_username(self):
        """Test: register/start requires username in request."""
        response = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={}
        )
        
        # Should reject missing username
        assert response.status_code == 422  # Validation error
    
    def test_authenticate_start_requires_username(self):
        """Test: authenticate/start requires username in request."""
        response = client.post(
            "/api/v1/auth/webauthn/authenticate/start",
            json={}
        )
        
        # Should reject missing username
        assert response.status_code == 422
    
    def test_register_finish_requires_attestation(self):
        """Test: register/finish requires attestation response."""
        response = client.post(
            "/api/v1/auth/webauthn/register/finish",
            json={"username": "user@example.com"}
        )
        
        # Should reject missing attestation
        assert response.status_code == 422
    
    def test_authenticate_finish_requires_assertion(self):
        """Test: authenticate/finish requires assertion response."""
        response = client.post(
            "/api/v1/auth/webauthn/authenticate/finish",
            json={"username": "user@example.com"}
        )
        
        # Should reject missing assertion
        assert response.status_code == 422


class TestWebAuthnResponseStructure:
    """Test response structure and format."""
    
    def test_register_start_response_is_json(self):
        """Test: Challenge response is valid JSON."""
        response = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": "user@example.com"}
        )
        
        assert response.status_code == 200
        # Should be valid JSON
        data = response.json()
        assert isinstance(data, dict)
    
    def test_challenge_values_are_strings(self):
        """Test: Challenge and credential IDs are base64url strings."""
        response = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": "user@example.com"}
        )
        
        assert response.status_code == 200
        data = response.json()
        
        # Challenge should be a base64url string
        assert isinstance(data["challenge"], str)
        # Should not contain padding (RFC 4648 urlsafe, no padding)
        assert "=" not in data["challenge"] or data["challenge"].endswith("=")


class TestWebAuthnUserIdentifier:
    """Test user identification in WebAuthn operations."""
    
    def test_user_id_is_consistent(self):
        """Test: Same user gets same user ID in challenge."""
        username = "consistentuser@example.com"
        
        response1 = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": username}
        )
        
        response2 = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": username}
        )
        
        data1 = response1.json()
        data2 = response2.json()
        
        # Same user should get same user ID
        assert data1["user"]["id"] == data2["user"]["id"]
    
    def test_different_users_get_different_ids(self):
        """Test: Different users get different user IDs."""
        response1 = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": "user1@example.com"}
        )
        
        response2 = client.post(
            "/api/v1/auth/webauthn/register/start",
            json={"username": "user2@example.com"}
        )
        
        data1 = response1.json()
        data2 = response2.json()
        
        # Different users should get different IDs
        assert data1["user"]["id"] != data2["user"]["id"]


class TestWebAuthnChallengeProperties:
    """Test challenge generation and properties."""
    
    def test_challenges_are_unique(self):
        """Test: Different challenge requests produce different challenges."""
        response1 = client.post(
            "/api/v1/auth/webauthn/authenticate/start",
            json={"username": "user@example.com"}
        )
        
        response2 = client.post(
            "/api/v1/auth/webauthn/authenticate/start",
            json={"username": "user@example.com"}
        )
        
        data1 = response1.json()
        data2 = response2.json()
        
        # Challenges should be different (for security)
        assert data1["challenge"] != data2["challenge"]
    
    def test_challenge_length_is_reasonable(self):
        """Test: Challenge length is cryptographically sufficient."""
        response = client.post(
            "/api/v1/auth/webauthn/authenticate/start",
            json={"username": "user@example.com"}
        )
        
        data = response.json()
        challenge = data["challenge"]
        
        # Base64url encoding: 32 bytes -> 43 characters (with padding 44)
        # We expect at least 32 bytes of random data
        # Base64 encoding: 32 bytes -> 43 characters
        import base64
        padded_challenge = challenge + "=" * (4 - len(challenge) % 4)
        decoded = base64.urlsafe_b64decode(padded_challenge)
        
        # Should be at least 32 bytes
        assert len(decoded) >= 32
