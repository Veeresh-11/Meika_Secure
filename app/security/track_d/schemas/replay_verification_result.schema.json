{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReplayVerificationResult",
  "type": "object",
  "required": ["valid", "status", "details"],
  "properties": {
    "valid": {
      "type": "boolean",
      "description": "Whether replay verification succeeded"
    },
    "status": {
      "type": "string",
      "enum": [
        "CHAIN_VALID",
        "CHAIN_BROKEN",
        "HASH_MISMATCH",
        "SEQUENCE_ERROR",
        "MISSING_RECORD"
      ]
    },
    "details": {
      "type": "object",
      "description": "Replay diagnostic details",
      "additionalProperties": false,
      "properties": {
        "failure_stage": {
          "type": "string"
        },
        "record_hash": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "additionalProperties": false
}
