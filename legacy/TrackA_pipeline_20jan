# app/security/pipeline.py

from datetime import datetime
from typing import Optional

from app.security.context import SecurityContext
from app.security.decision import SecurityDecision, DecisionOutcome
from app.security.errors import SecurityInvariantViolation

from app.security.risk.engine import evaluate_risk
from app.security.grants.engine import resolve_authority
from app.security.containment.engine import evaluate_containment

from app.security.evidence.engine import (
    build_evidence_record,
    append_evidence_record,
)

from app.security.observability.emitter import SecurityEventEmitter
from app.security.observability.events import (
    SecurityEvent,
    SecurityEventType,
)
# ------------------------------------------------------------------
# Legacy policy adapter (Sprint A1 compatibility)
# ------------------------------------------------------------------
from app.security.policy.engine import PolicyEngine

def evaluate_policy(context):
    """
    A1-compatible policy evaluation shim.
    PolicyEngine is expected to be injected by bootstrap.
    """
    engine = getattr(context, "_policy_engine", None)
    if engine is None:
        raise RuntimeError("PolicyEngine not bound to SecurityContext")
    return engine.evaluate(context)

class SecureIDKernel:
    """
    Secure ID Decision Kernel

    Authoritative, evidence-first, fail-closed.
    """

    def __init__(
        self,
        *,
        event_emitter: Optional[SecurityEventEmitter] = None,
    ):
        self._event_emitter = event_emitter

    # ---------------------------------------------------------
    # Public entry point (ONLY ONE)
    # ---------------------------------------------------------
    def evaluate(self, context: SecurityContext) -> SecurityDecision:
        issued_at = datetime.utcnow()

        # 1️⃣ Canonicalize context
        canonical_ctx = context.canonicalize()

        # 2️⃣ Invariant pre-checks (fail hard)
        violations = canonical_ctx.detect_invariant_violations()
        if violations:
            return self._deny_with_evidence(
                context=canonical_ctx,
                reason="Invariant violation",
                metadata={"violations": violations},
                issued_at=issued_at,
            )

        # 3️⃣ Containment evaluation (override, but provable)
        containment_result = evaluate_containment(canonical_ctx)
        if containment_result.is_contained:
            return self._deny_with_evidence(
                context=canonical_ctx,
                reason="Principal under containment",
                metadata={"containment": containment_result.reason},
                issued_at=issued_at,
            )

        # 4️⃣ Policy evaluation (pure)
        policy_result = evaluate_policy(canonical_ctx)

        # 5️⃣ Risk evaluation (restrictive only)
        risk_assessment = evaluate_risk(
            context=canonical_ctx,
            policy_result=policy_result,
        )

        # 6️⃣ Authority resolution (JIT leases only)
        authority_leases = resolve_authority(
            context=canonical_ctx,
            policy_result=policy_result,
            risk=risk_assessment,
        )

        # 7️⃣ Assemble decision draft (NOT YET REAL)
        draft_decision = SecurityDecision(
            decision_id=SecurityDecision.compute_id(
                canonical_ctx,
                policy_result,
                risk_assessment,
                authority_leases,
                issued_at,
            ),
            outcome=self._final_outcome(policy_result, risk_assessment),
            leases=authority_leases,
            restrictions=risk_assessment.restrictions,
            evidence_hash=None,  # not yet committed
            issued_at=issued_at,
        )

        # 8️⃣ Build & commit evidence (MANDATORY)
        evidence = build_evidence_record(
            context=canonical_ctx,
            policy=policy_result,
            risk=risk_assessment,
            authority=authority_leases,
            decision=draft_decision,
        )

        evidence_hash = append_evidence_record(evidence)
        if not evidence_hash:
            # Kernel failure → fail closed
            raise SecurityInvariantViolation(
                code="EVIDENCE_COMMIT_FAILED",
                details="Decision denied because evidence could not be committed",
            )

        final_decision = draft_decision.with_evidence(evidence_hash)

        # 9️⃣ Emit observability (NON-AUTHORITATIVE)
        self._emit_event(
            canonical_ctx,
            final_decision,
            SecurityEventType.AUTH_DECISION,
        )

        return final_decision

    # ---------------------------------------------------------
    # Internal helpers
    # ---------------------------------------------------------
    def _final_outcome(self, policy_result, risk_assessment) -> DecisionOutcome:
        if policy_result.outcome == DecisionOutcome.DENY:
            return DecisionOutcome.DENY

        if risk_assessment.forces_deny:
            return DecisionOutcome.DENY

        if (
            policy_result.outcome == DecisionOutcome.RESTRICT
            or risk_assessment.restrictions
        ):
            return DecisionOutcome.RESTRICT

        return DecisionOutcome.ALLOW

    def _deny_with_evidence(
        self,
        *,
        context: SecurityContext,
        reason: str,
        metadata: dict,
        issued_at: datetime,
    ) -> SecurityDecision:
        decision = SecurityDecision(
            decision_id=SecurityDecision.compute_id(
                context,
                reason,
                issued_at,
            ),
            outcome=DecisionOutcome.DENY,
            leases=[],
            restrictions=[],
            evidence_hash=None,
            issued_at=issued_at,
            reason=reason,
        )

        evidence = build_evidence_record(
            context=context,
            policy=None,
            risk=None,
            authority=[],
            decision=decision,
            extra_metadata=metadata,
        )

        evidence_hash = append_evidence_record(evidence)
        if not evidence_hash:
            raise SecurityInvariantViolation(
                code="EVIDENCE_COMMIT_FAILED",
                details="Containment / invariant denial not recorded",
            )

        final_decision = decision.with_evidence(evidence_hash)

        self._emit_event(
            context,
            final_decision,
            SecurityEventType.AUTH_DENIED,
        )

        return final_decision

    def _emit_event(
        self,
        context: SecurityContext,
        decision: SecurityDecision,
        event_type: SecurityEventType,
    ) -> None:
        if not self._event_emitter:
            return

        try:
            self._event_emitter.emit(
                SecurityEvent(
                    event_type=event_type,
                    timestamp=datetime.utcnow(),
                    principal_id=context.principal_id,
                    decision=decision.outcome.value,
                    policy_version=decision.policy_version,
                    metadata={
                        "intent": context.intent,
                        "decision_id": decision.decision_id,
                        "evidence_hash": decision.evidence_hash,
                    },
                )
            )
        except Exception:
            # Observability must never affect enforcement
            pass

# ------------------------------------------------------------------
# Backward compatibility (Sprint A1–A3)
# ------------------------------------------------------------------

SecurityPipeline = SecureIDKernel
