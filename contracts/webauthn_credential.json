{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WebAuthnCredential",
  "type": "object",
  "required": [
    "credential_id",
    "public_key",
    "aaguid",
    "attestation_type",
    "created_at",
    "evidence_ref"
  ],
  "properties": {
    "credential_id": { "type": "string" },
    "public_key": { "type": "string" },
    "aaguid": { "type": "string" },
    "attestation_type": {
      "type": "string",
      "enum": ["none", "basic", "attca"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_ref": { "type": "string" }
  },
  "additionalProperties": false
}
