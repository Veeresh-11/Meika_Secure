{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeviceRegistrationProof",
  "type": "object",
  "required": [
    "user_id",
    "device_public_key",
    "nonce",
    "timestamp",
    "signature"
  ],
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Authenticated user requesting device registration"
    },
    "device_public_key": {
      "type": "string",
      "description": "Public key generated by the device"
    },
    "nonce": {
      "type": "string",
      "description": "Single-use nonce to prevent replay"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Time of proof generation"
    },
    "signature": {
      "type": "string",
      "description": "Signature over (user_id + device_public_key + nonce + timestamp)"
    }
  },
  "additionalProperties": false
}
